{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A board/project that holds tasks.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "createdAt", "updatedAt", "ownerId"]
    },
    "Task": {
      "title": "Task",
      "description": "A single task in a project.",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["todo", "in_progress", "done", "stuck"] },
        "content": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "projectId": { "type": "string" }
      },
      "required": ["status", "content", "createdAt", "updatedAt", "projectId"]
    }
  },
  "firestore": {
    "projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "User's projects"
    },
    "tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Tasks belonging to projects"
    }
  }
}
